{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "model": "openai/gpt-5.4-mini",
  "permission": {
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls": "allow",
      "ls *": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  }
}
